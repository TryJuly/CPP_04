#################################################################################################################
#                                           VARIABLES SET                                                       #
#################################################################################################################
NAME = exec

CC = c++
FLAGS =  -std=c++98

INCLUDES = includes
OBJ_DIR = objets

VPATH = srcs
SRCS = main.cpp AMateria.cpp Character.cpp Cure.cpp Ice.cpp \
        MateriaSource.cpp

OBJS = ${patsubst %.cpp, ${OBJ_DIR}/%.o, ${SRCS}}
#################################################################################################################
#                                           RULES COMPILATION                                                   #
#################################################################################################################
all: ${NAME}

${NAME}: ${OBJS}
	${CC} ${FLAGS} ${OBJS} -I ${INCLUDES} -o ${NAME}

${OBJ_DIR}/%.o: %.cpp
	@mkdir -p ${OBJ_DIR}
	${CC} ${FLAGS} -c $< -o $@ -I${INCLUDES}
#################################################################################################################
#                                           RULES CLEAN                                                         #
#################################################################################################################
clean:
	rm -rf ${OBJ_DIR}

fclean: clean
	rm -rf ${NAME}

re: fclean all
#################################################################################################################
#                                           NO RELINK                                                           #
#################################################################################################################
.PHONY: all clean fclean re