#################################################################################################################
#                                           VARIABLES SET                                                       #
#################################################################################################################
NAME = exec

CXX = c++
CXXFLAGS = -Wall -Wextra -Werror -std=c++98

INCLUDES = header
OBJ_DIR = objets

VPATH = source
SRCS = main.cpp Animal.cpp Dog.cpp Cat.cpp WrongAnimal.cpp \
		WrongCat.cpp

OBJS = ${patsubst %.cpp, ${OBJ_DIR}/%.o, ${SRCS}}
#################################################################################################################
#                                           RULES COMPILATION                                                   #
#################################################################################################################
all: ${NAME}

${NAME}: ${OBJS}
	${CXX} ${CXXFLAGS} ${OBJS} -I ${INCLUDES} -o ${NAME}

${OBJ_DIR}/%.o: %.cpp
	@mkdir -p ${OBJ_DIR}
	${CXX} ${CXXFLAGS} -c $< -o $@ -I${INCLUDES}
#################################################################################################################
#                                           RULES CLEAN                                                         #
#################################################################################################################
clean:
	rm -rf ${OBJ_DIR}

fclean: clean
	rm -rf ${NAME}

re: fclean all
#################################################################################################################
#                                           NO RELINK                                                           #
#################################################################################################################
.PHONY: all clean fclean re